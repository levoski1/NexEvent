{
  "name": "@nexevent/backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nexevent/config": "*",
    "@nexevent/shared-types": "*",
    "@nexevent/shared-utils": "*",
    "express": "4.19.2",
    "mongoose": "8.4.0",
    "bullmq": "5.7.8",
    "ioredis": "5.3.2",
    "zod": "3.23.8",
    "pino": "9.1.0",
    "pino-pretty": "11.0.0",
    "swagger-ui-express": "5.0.1",
    "swagger-jsdoc": "6.2.8",
    "jsonwebtoken": "9.0.2",
    "bcryptjs": "2.4.3",
    "cors": "2.8.5",
    "helmet": "7.1.0",
    "express-rate-limit": "7.3.1",
    "nodemailer": "6.9.13",
    "axios": "1.7.2",
    "uuid": "10.0.0"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.6",
    "@types/bcryptjs": "2.4.6",
    "@types/cors": "2.8.17",
    "@types/swagger-ui-express": "4.1.6",
    "@types/swagger-jsdoc": "6.0.4",
    "@types/nodemailer": "6.4.15",
    "@types/uuid": "10.0.0",
    "ts-node-dev": "2.0.0",
    "typescript": "5.4.5",
    "vitest": "1.6.0",
    "supertest": "7.0.0",
    "@types/supertest": "6.0.2"
  }
}
