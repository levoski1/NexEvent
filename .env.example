# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ─── Backend ───────────────────────────────────────────────────────────────────
BACKEND_PORT=4000
JWT_SECRET=change_me_in_production_min_32_chars
JWT_EXPIRES_IN=7d
ADMIN_API_KEY=change_me_admin_key

# ─── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/nexevent

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Soroban / Stellar ─────────────────────────────────────────────────────────
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
POLL_INTERVAL_MS=5000
START_LEDGER=0

# ─── Action Executors ──────────────────────────────────────────────────────────
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_MAX_RETRIES=3

DISCORD_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@nexevent.io

# ─── Queue ─────────────────────────────────────────────────────────────────────
QUEUE_CONCURRENCY=5
QUEUE_MAX_RETRIES=3
QUEUE_BACKOFF_MS=5000

# ─── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:4000/api/v1
